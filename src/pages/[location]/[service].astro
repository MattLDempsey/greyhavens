---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import FAQ from '../../components/FAQ.astro';
import CTABand from '../../components/CTABand.astro';
import ServiceSchema from '../../components/schema/ServiceSchema.astro';
import FAQSchema from '../../components/schema/FAQSchema.astro';
import BreadcrumbSchema from '../../components/schema/BreadcrumbSchema.astro';
import { comboPages } from '../../data/combo-pages';
import { getServiceBySlug } from '../../data/services';
import { locations } from '../../data/locations';

export function getStaticPaths() {
  return comboPages.map(page => ({
    params: { location: page.locationSlug, service: page.serviceSlug },
    props: { page },
  }));
}

const { page } = Astro.props;
const fullService = getServiceBySlug(page.serviceSlug);

const blogPosts = [
  { title: 'Do I Need a Consumer Unit Upgrade?', href: '/blog/do-i-need-a-consumer-unit-upgrade/', services: ['consumer-unit-replacement', 'rewires', 'eicr-certificates', 'fault-finding'] },
  { title: 'How Much Does an EICR Cost?', href: '/blog/how-much-does-an-eicr-cost/', services: ['eicr-certificates', 'fault-finding', 'consumer-unit-replacement', 'rewires'] },
  { title: 'Smart Home Wiring for New Builds', href: '/blog/smart-home-wiring-new-builds/', services: ['smart-home-installation', 'ethernet-wiring', 'home-cinema-wiring', 'home-wifi-systems', 'cctv-installation', 'lighting-installation', 'ev-charger-installation'] },
  { title: 'EV Charger Installation: Home Charging Explained', href: '/blog/ev-charger-installation-home-charging-explained/', services: ['ev-charger-installation', 'consumer-unit-replacement', 'smart-home-installation'] },
  { title: 'Rewiring a House: Signs, Costs, and What to Expect', href: '/blog/rewiring-a-house-signs-costs-and-what-to-expect/', services: ['rewires', 'consumer-unit-replacement', 'eicr-certificates', 'fault-finding', 'lighting-installation'] },
  { title: 'What Is Part P and Why Does It Matter?', href: '/blog/what-is-part-p-and-why-does-it-matter/', services: ['eicr-certificates', 'consumer-unit-replacement', 'rewires', 'ev-charger-installation'] },
  { title: 'Smart Home on a Budget: Where to Start', href: '/blog/smart-home-on-a-budget-where-to-start/', services: ['smart-home-installation', 'home-wifi-systems', 'ethernet-wiring', 'lighting-installation', 'cctv-installation'] },
  { title: 'Landlord Electrical Safety: Your Legal Obligations', href: '/blog/landlord-electrical-safety-legal-obligations/', services: ['eicr-certificates', 'consumer-unit-replacement', 'fault-finding', 'rewires'] },
  { title: 'Can I Install My Own EV Charger?', href: '/blog/can-i-install-my-own-ev-charger/', services: ['ev-charger-installation', 'consumer-unit-replacement'] },
  { title: 'How Often Should Electrics Be Tested?', href: '/blog/how-often-should-electrics-be-tested/', services: ['eicr-certificates', 'fault-finding', 'consumer-unit-replacement'] },
  { title: 'Cat5 vs Cat6 vs Cat6a: Which Ethernet Cable Do You Need?', href: '/blog/cat5-vs-cat6-vs-cat6a-ethernet-cable-guide/', services: ['ethernet-wiring', 'home-wifi-systems', 'home-cinema-wiring'] },
  { title: 'How to Improve WiFi in an Old House', href: '/blog/how-to-improve-wifi-in-an-old-house/', services: ['home-wifi-systems', 'ethernet-wiring', 'smart-home-installation'] },
  { title: 'What Does an Electrician Charge Per Hour in Essex?', href: '/blog/what-does-an-electrician-charge-per-hour/', services: ['fault-finding', 'consumer-unit-replacement', 'rewires', 'lighting-installation'] },
  { title: 'Smart Home Security Systems: A Complete Guide', href: '/blog/smart-home-security-systems-guide/', services: ['cctv-installation', 'smart-home-installation', 'ethernet-wiring'] },
  { title: 'Kitchen Electrical Requirements for Renovations', href: '/blog/kitchen-electrical-requirements-renovations/', services: ['rewires', 'lighting-installation', 'consumer-unit-replacement', 'fault-finding'] },
  { title: 'Home Office Lighting and Power Setup', href: '/blog/home-office-lighting-and-power-setup/', services: ['lighting-installation', 'ethernet-wiring', 'home-wifi-systems', 'fault-finding'] },
  { title: 'Garage and Workshop Electrical Installation', href: '/blog/garage-workshop-electrical-installation/', services: ['consumer-unit-replacement', 'lighting-installation', 'ev-charger-installation', 'fault-finding'] },
  { title: 'Power Surge Protection for Your Home', href: '/blog/power-surge-protection-for-your-home/', services: ['consumer-unit-replacement', 'smart-home-installation', 'fault-finding'] },
];
const relatedPosts = blogPosts.filter(post => post.services.includes(page.serviceSlug));
const otherLocations = locations.filter(l => l.slug !== page.locationSlug);
const relatedComboPages = comboPages.filter(
  p => p.locationSlug === page.locationSlug && p.serviceSlug !== page.serviceSlug
);
---

<BaseLayout title={page.seoTitle} description={page.seoDescription}>
  <ServiceSchema
    slot="schema"
    name={`${page.serviceName} in ${page.locationName}`}
    description={page.seoDescription}
    url={`/${page.locationSlug}/${page.serviceSlug}/`}
    category={fullService?.category === 'electrical' ? 'Electrical Services' : fullService?.category === 'compliance' ? 'Property & Compliance' : 'Smart Home & Technology'}
  />
  <FAQSchema slot="schema" items={page.faqs} />
  <BreadcrumbSchema
    slot="schema"
    items={[
      { name: 'Home', url: '/' },
      { name: page.locationName, url: `/locations/${page.locationSlug}/` },
      { name: page.serviceName, url: `/${page.locationSlug}/${page.serviceSlug}/` },
    ]}
  />

  <Hero
    compact
    subtitle={`${page.serviceName} — ${page.locationName}`}
    title={page.headline}
    description={page.intro.slice(0, 160) + '...'}
    primaryCta={{ text: 'Request a Quote', href: `/contact/?service=${encodeURIComponent(page.serviceName)}` }}
    secondaryCta={{ text: 'Get in Touch', href: '/contact/' }}
  />

  <!-- Main Content -->
  <section class="section">
    <div class="container">
      <div class="combo-layout">
        <div class="combo-main">
          <!-- Intro -->
          <div class="combo-intro">
            <p>{page.intro}</p>
          </div>

          <!-- Local Angle -->
          <div class="combo-block">
            <h2>{page.serviceName} for {page.locationName} Properties</h2>
            <hr class="gold-line gold-line--left" />
            <p>{page.localAngle}</p>
          </div>

          <!-- Why Choose Us Locally -->
          <div class="combo-block">
            <h2>Why Choose Grey Havens in {page.locationName}</h2>
            <hr class="gold-line gold-line--left" />
            <ul class="combo-checklist">
              {page.whyLocal.map(item => (
                <li>{item}</li>
              ))}
            </ul>
          </div>

          <!-- Full Service Details -->
          {fullService && (
            <div class="combo-block">
              <h2>What's Included</h2>
              <hr class="gold-line gold-line--left" />
              <ul class="combo-checklist">
                {fullService.includes.map((item: string) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          )}

          {fullService && (
            <div class="combo-block">
              <h2>Signs You May Need This Service</h2>
              <hr class="gold-line gold-line--left" />
              <ul class="combo-checklist">
                {fullService.signs.map((item: string) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          )}
        </div>

        <!-- Sidebar -->
        <aside class="combo-sidebar">
          <div class="sidebar-card card">
            <h3>Get a Quote in {page.locationName}</h3>
            <p>Free, no-obligation quote for {page.serviceName.toLowerCase()} in {page.locationName}.</p>
            <a href={`/contact/?service=${encodeURIComponent(page.serviceName)}`} class="btn btn--primary" style="width: 100%; text-align: center;">Request a Quote</a>
            <div class="sidebar-card__divider"></div>
            <div class="sidebar-card__contact">
              <span class="sidebar-card__label">Or email us</span>
              <a href="mailto:hello@thegreyhavens.co.uk" class="sidebar-card__phone">hello@thegreyhavens.co.uk</a>
            </div>
          </div>

          {relatedComboPages.length > 0 && (
            <div class="sidebar-card card">
              <h3>More Services in {page.locationName}</h3>
              <ul class="sidebar-links">
                {relatedComboPages.map(p => (
                  <li><a href={`/${p.locationSlug}/${p.serviceSlug}/`}>{p.serviceName}</a></li>
                ))}
              </ul>
            </div>
          )}

          {fullService && (
            <div class="sidebar-card card">
              <h3>Full Service Details</h3>
              <p>View the complete {page.serviceName.toLowerCase()} service page for detailed information.</p>
              <a href={`/services/${page.serviceSlug}/`} class="sidebar-link-arrow">
                {page.serviceName}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </a>
            </div>
          )}

          {relatedPosts.length > 0 && (
            <div class="sidebar-card card">
              <h3>Related Articles</h3>
              <ul class="sidebar-links">
                {relatedPosts.map(post => (
                  <li><a href={post.href}>{post.title}</a></li>
                ))}
              </ul>
            </div>
          )}

          <div class="sidebar-card card">
            <h3>Other Areas</h3>
            <div class="sidebar-areas">
              {otherLocations.map(loc => (
                <a href={`/locations/${loc.slug}/`} class="sidebar-area-tag">{loc.name}</a>
              ))}
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  {page.faqs.length > 0 && (
    <section class="section--dark">
      <FAQ items={page.faqs} title={`${page.serviceName} in ${page.locationName} — FAQs`} />
    </section>
  )}

  <CTABand
    title={`Need ${page.serviceName} in ${page.locationName}?`}
    description={`Get in touch for a free, no-obligation quote. We cover ${page.locationName} and all surrounding areas.`}
    primaryHref={`/contact/?service=${encodeURIComponent(page.serviceName)}`}
  />
</BaseLayout>

<style>
  .combo-layout {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 4rem;
    align-items: start;
  }

  .combo-intro p {
    font-size: 1.1rem;
    line-height: 1.85;
    color: var(--color-silver-light);
  }

  .combo-block {
    margin-top: 3rem;
    padding-top: 3rem;
    border-top: 1px solid rgba(75, 80, 87, 0.2);
  }

  .combo-block h2 {
    font-size: 1.5rem;
  }

  .combo-block p {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-silver);
  }

  .combo-checklist {
    display: grid;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .combo-checklist li {
    position: relative;
    padding-left: 1.75rem;
    font-size: 0.95rem;
    color: var(--color-silver);
    line-height: 1.6;
  }

  .combo-checklist li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6rem;
    width: 10px;
    height: 2px;
    background-color: var(--color-gold);
  }

  /* Sidebar */
  .combo-sidebar {
    position: sticky;
    top: 6rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .sidebar-card h3 {
    font-size: 1rem;
    color: var(--color-gold);
    margin-bottom: 0.75rem;
  }

  .sidebar-card p {
    font-size: 0.9rem;
    opacity: 0.8;
    margin-bottom: 1.25rem;
  }

  .sidebar-card__divider {
    height: 1px;
    background-color: rgba(75, 80, 87, 0.3);
    margin: 1.25rem 0;
  }

  .sidebar-card__label {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-silver);
    opacity: 0.5;
    margin-bottom: 0.25rem;
  }

  .sidebar-card__phone {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-white);
    text-decoration: none;
  }

  .sidebar-card__phone:hover {
    color: var(--color-gold);
  }

  .sidebar-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .sidebar-links a {
    font-size: 0.875rem;
    color: var(--color-silver);
    text-decoration: none;
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(75, 80, 87, 0.15);
    transition: color 0.3s;
  }

  .sidebar-links a:hover {
    color: var(--color-gold);
  }

  .sidebar-link-arrow {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-gold);
    text-decoration: none;
  }

  .sidebar-link-arrow:hover {
    gap: 0.625rem;
    color: var(--color-gold);
  }

  .sidebar-areas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .sidebar-area-tag {
    padding: 0.35rem 0.75rem;
    background-color: var(--color-charcoal);
    border: 1px solid rgba(75, 80, 87, 0.3);
    border-radius: var(--radius);
    font-size: 0.8rem;
    color: var(--color-silver);
    text-decoration: none;
    transition: all 0.3s;
  }

  .sidebar-area-tag:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }

  @media (max-width: 900px) {
    .combo-layout {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .combo-sidebar {
      position: static;
    }
  }
</style>
