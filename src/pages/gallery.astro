---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CTABand from '../components/CTABand.astro';

const categories = ['All', 'Electrical', 'Smart Home', 'EV Charging'];

const projects = [
  {
    title: 'Consumer Unit Upgrade',
    category: 'Electrical',
    description: 'Full consumer unit replacement with surge protection and RCD coverage for a period property in Colchester.',
  },
  {
    title: 'Whole-Home Automation',
    category: 'Smart Home',
    description: 'Complete smart lighting, heating, and security integration across a four-bedroom home in Dedham.',
  },
  {
    title: 'EV Charger Installation',
    category: 'EV Charging',
    description: 'Dedicated 7.4kW EV charging point with load management, installed on a new-build driveway in Ipswich.',
  },
  {
    title: 'Full Property Rewire',
    category: 'Electrical',
    description: 'Complete rewire of a 1930s semi-detached, including new consumer unit, lighting circuits, and sockets throughout.',
  },
  {
    title: 'Home Network Infrastructure',
    category: 'Smart Home',
    description: 'Structured Cat6a cabling to every room with centralised network cabinet and Wi-Fi access point deployment.',
  },
  {
    title: 'Dual EV Charging Setup',
    category: 'EV Charging',
    description: 'Two-vehicle charging installation with dynamic load balancing, ensuring safe operation alongside existing demand.',
  },
];
---

<BaseLayout
  title="Gallery | Grey Havens — Completed Projects"
  description="View our portfolio of completed electrical, smart home, and EV charging projects across Essex and Suffolk. Quality workmanship you can see."
>
  <meta name="robots" content="noindex, follow" slot="schema" />
  <!-- Hero -->
  <Hero
    compact
    subtitle="Our Work"
    title="Project Gallery"
    description="A selection of completed projects showcasing our electrical, smart home, and EV charging work across Essex and Suffolk."
  />

  <!-- Gallery Section -->
  <section class="section">
    <div class="container">

      <!-- Coming Soon Notice -->
      <div class="gallery-notice">
        <p class="gallery-notice__text">Project photos coming soon — we're currently building out our portfolio. Below is a preview of the types of work we deliver.</p>
      </div>

      <!-- Filter Buttons -->
      <div class="gallery-filters">
        {categories.map((cat, i) => (
          <button
            class:list={['filter-btn', { 'filter-btn--active': i === 0 }]}
            type="button"
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Project Grid -->
      <div class="gallery-grid">
        {projects.map((project) => (
          <article class="project-card">
            <div class="project-card__image">
              <svg class="project-card__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
              </svg>
              <span class="project-card__image-label">Photo Coming Soon</span>
            </div>
            <div class="project-card__body">
              <span class="project-card__tag">{project.category}</span>
              <h3 class="project-card__title">{project.title}</h3>
              <p class="project-card__desc">{project.description}</p>
            </div>
          </article>
        ))}
      </div>

    </div>
  </section>

  <!-- CTA Band -->
  <CTABand
    title="Have a Project in Mind?"
    description="We'd love to add your project to our portfolio. Get in touch for a free, no-obligation quote."
    secondaryText="View Our Services"
    secondaryHref="/services/"
  />
</BaseLayout>

<style>
  /* --- Coming Soon Notice --- */
  .gallery-notice {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 2.5rem;
    padding: 1.25rem 2rem;
    background: rgba(198, 168, 106, 0.06);
    border: 1px solid rgba(198, 168, 106, 0.15);
    border-radius: var(--radius-lg);
  }

  .gallery-notice__text {
    font-size: 0.95rem;
    color: var(--color-silver);
    opacity: 0.85;
    margin: 0;
  }

  /* --- Filter Buttons --- */
  .gallery-filters {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: 0.6rem 1.5rem;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: var(--color-silver);
    background: transparent;
    border: 1px solid rgba(75, 80, 87, 0.5);
    border-radius: var(--radius);
    cursor: pointer;
    transition: all var(--transition);
  }

  .filter-btn:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }

  .filter-btn--active {
    background-color: var(--color-gold);
    border-color: var(--color-gold);
    color: var(--color-charcoal);
    font-weight: 600;
  }

  .filter-btn--active:hover {
    background-color: var(--color-gold-dark);
    border-color: var(--color-gold-dark);
    color: var(--color-charcoal);
  }

  /* --- Gallery Grid --- */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  /* --- Project Card --- */
  .project-card {
    background-color: var(--color-charcoal-light);
    border: 1px solid rgba(75, 80, 87, 0.4);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--transition);
  }

  .project-card:hover {
    border-color: var(--color-gold);
    transform: translateY(-3px);
    box-shadow: var(--shadow);
  }

  .project-card__image {
    width: 100%;
    aspect-ratio: 16 / 10;
    background: linear-gradient(135deg, var(--color-charcoal) 0%, var(--color-steel) 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    border-bottom: 1px solid rgba(75, 80, 87, 0.3);
  }

  .project-card__icon {
    width: 32px;
    height: 32px;
    color: var(--color-silver);
    opacity: 0.25;
  }

  .project-card__image-label {
    font-size: 0.75rem;
    color: var(--color-silver);
    opacity: 0.3;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .project-card__body {
    padding: 1.5rem;
  }

  .project-card__tag {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-gold);
    background: rgba(198, 168, 106, 0.1);
    padding: 0.3rem 0.75rem;
    border-radius: var(--radius);
    margin-bottom: 0.875rem;
  }

  .project-card__title {
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--color-white);
    margin-bottom: 0.625rem;
  }

  .project-card__desc {
    font-size: 0.9rem;
    color: var(--color-silver);
    opacity: 0.8;
    line-height: 1.65;
    margin: 0;
  }

  /* --- Responsive --- */
  @media (max-width: 992px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }

    .gallery-filters {
      gap: 0.5rem;
    }

    .filter-btn {
      padding: 0.5rem 1.1rem;
      font-size: 0.8rem;
    }
  }
</style>
