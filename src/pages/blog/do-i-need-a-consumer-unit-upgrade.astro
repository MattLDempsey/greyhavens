const title = 'Do I Need a Consumer Unit Upgrade?';
const description = 'Signs your fuse box needs replacing, the benefits of a modern consumer unit, UK regulations, and what to expect from a consumer unit upgrade.';
const publishDate = '2026-02-10';
const category = 'Electrical';
const readingTime = '6 min read';
---

<BaseLayout
  title={`${title} | Grey Havens Blog`}
  description={description}
