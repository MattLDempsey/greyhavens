    padding: 2rem;
    background-color: var(--color-charcoal-light);
    border: 1px solid rgba(75, 80, 87, 0.4);
    border-radius: var(--radius-lg);
  }

  .article-services h3 {
    margin-top: 0;
    margin-bottom: 1rem;
    font-size: 1.1rem;
    color: var(--color-gold);
  }

  .article-services ul {
    margin: 0;
    padding: 0;
  }

  .article-services li {
    padding-left: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .article-services li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.7rem;
    width: 8px;
    height: 2px;
    background-color: var(--color-gold);
  }

  .article-services a {
