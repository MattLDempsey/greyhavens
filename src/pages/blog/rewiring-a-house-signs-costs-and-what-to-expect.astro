          <ul>
            <li><a href="/services/rewires/">Rewiring</a></li>
            <li><a href="/services/consumer-unit-replacement/">Consumer Unit Replacement</a></li>
            <li><a href="/services/eicr-certificates/">EICR Certificates</a></li>
            <li><a href="/services/fault-finding/">Fault Finding & Diagnosis</a></li>
            <li><a href="/services/lighting-installation/">Lighting Installation</a></li>
          </ul>
        </div>
      </div>
    </div>
  </article>

