    letter-spacing: 0.1em;
    color: var(--color-gold);
    background: rgba(198, 168, 106, 0.1);
    border: 1px solid rgba(198, 168, 106, 0.2);
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius);
  }

