    margin-top: 0;
    margin-bottom: 1rem;
    font-size: 1.1rem;
    color: var(--color-gold);
  }

  .article-services ul {
    margin: 0;
    padding: 0;
  }

  .article-services li {
    padding-left: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .article-services li::before {
    content: '';
    position: absolute;
    left: 0;
