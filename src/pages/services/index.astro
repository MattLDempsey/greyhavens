---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CTABand from '../../components/CTABand.astro';
import { getServicesByCategory, serviceCategories } from '../../data/services';

const electrical = getServicesByCategory('electrical');
const smartHome = getServicesByCategory('smart-home');
---

<BaseLayout
  title="Our Services | Grey Havens Electrical & Smart Home"
  description="Electrical services, property compliance, and smart home installation across Essex and Suffolk. View our full range of professional services."
>
  <Hero
    compact
    subtitle="Our Services"
    title="Electrical & Smart Home Services"
    description="From essential electrical work and compliance inspections to complete smart home installations — we deliver quality across every service we offer."
    primaryCta={{ text: 'Request a Quote', href: '/contact/' }}
  />

  <!-- Electrical Services -->
  <section class="section" id="electrical">
    <div class="container">
      <div class="section__header">
        <span class="section__subtitle">Electrical</span>
        <h2>{serviceCategories.electrical.name}</h2>
        <p class="text-silver">{serviceCategories.electrical.description}</p>
      </div>
      <div class="grid grid--3">
        {electrical.map(s => (
          <ServiceCard name={s.name} slug={s.slug} description={s.shortDescription} />
        ))}
      </div>
    </div>
  </section>

  <!-- Smart Home -->
  <section class="section section--dark" id="smart-home">
    <div class="container">
      <div class="section__header">
        <span class="section__subtitle">Smart Home</span>
        <h2>{serviceCategories['smart-home'].name}</h2>
        <p class="text-silver">{serviceCategories['smart-home'].description}</p>
      </div>
      <div class="grid grid--3">
        {smartHome.map(s => (
          <ServiceCard name={s.name} slug={s.slug} description={s.shortDescription} />
        ))}
      </div>
    </div>
  </section>

  <CTABand />
</BaseLayout>
