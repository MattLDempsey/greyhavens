<div class="mobile-cta">
  <a href="tel:01206000000" class="mobile-cta__phone" aria-label="Call Grey Havens">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
    Call Us
  </a>
  <a href="/contact/" class="mobile-cta__quote">
    Request a Quote
  </a>
</div>

<style>
  .mobile-cta {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 40;
    background-color: var(--color-charcoal);
    border-top: 1px solid rgba(75, 80, 87, 0.4);
    padding: 0;
  }

  @media (max-width: 900px) {
    .mobile-cta {
      display: flex;
    }
    .site-footer {
      padding-bottom: 64px;
    }
    main {
      padding-bottom: 0;
    }
  }

  .mobile-cta__phone,
  .mobile-cta__quote {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    text-align: center;
    transition: background-color 0.2s;
  }

  .mobile-cta__phone {
    color: var(--color-silver-light);
    border-right: 1px solid rgba(75, 80, 87, 0.3);
  }

  .mobile-cta__phone:hover {
    background-color: var(--color-charcoal-light);
    color: var(--color-silver-light);
  }

  .mobile-cta__quote {
    background-color: var(--color-gold);
    color: var(--color-charcoal);
  }

  .mobile-cta__quote:hover {
    background-color: var(--color-gold-dark);
    color: var(--color-charcoal);
  }
</style>
