---
---
<div class="mobile-cta">
  <a href="/contact/" class="mobile-cta__quote">
    Request a Quote
  </a>
</div>

<style>
  .mobile-cta {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 40;
    background-color: var(--color-charcoal);
    border-top: 1px solid rgba(75, 80, 87, 0.4);
    padding: 0;
  }

  @media (max-width: 900px) {
    .mobile-cta {
      display: flex;
    }
    .site-footer {
      padding-bottom: 64px;
    }
    main {
      padding-bottom: 0;
    }
  }

  .mobile-cta__quote {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    text-align: center;
    transition: background-color 0.2s;
    flex: 1;
    background-color: var(--color-gold);
    color: var(--color-charcoal);
  }

  .mobile-cta__quote:hover {
    background-color: var(--color-gold-dark);
    color: var(--color-charcoal);
  }
</style>
