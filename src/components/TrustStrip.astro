---
const items = [
  { label: 'Fully Certified', desc: 'All work tested & certified' },
  { label: 'Premium Quality', desc: 'Quality materials & workmanship' },
  { label: 'Smart Home Experts', desc: 'Modern connected home systems' },
  { label: 'Essex & Suffolk', desc: 'Local service you can trust' },
];
---

<section class="trust-strip">
  <div class="container">
    <div class="trust-strip__grid">
      {items.map(item => (
        <div class="trust-strip__item">
          <span class="trust-strip__label">{item.label}</span>
          <span class="trust-strip__desc">{item.desc}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .trust-strip {
    background-color: var(--color-charcoal-light);
    border-top: 1px solid rgba(198, 168, 106, 0.1);
    border-bottom: 1px solid rgba(198, 168, 106, 0.1);
    padding: 2rem 0;
  }

  .trust-strip__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .trust-strip__item {
    text-align: center;
    padding: 0.75rem 0.5rem;
  }

  .trust-strip__label {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-gold);
    letter-spacing: 0.04em;
    margin-bottom: 0.25rem;
  }

  .trust-strip__desc {
    font-size: 0.8rem;
    color: var(--color-silver);
    opacity: 0.6;
  }

  @media (max-width: 768px) {
    .trust-strip__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 420px) {
    .trust-strip__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
