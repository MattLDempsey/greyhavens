---
interface Props {
  title?: string;
  description?: string;
  primaryText?: string;
  primaryHref?: string;
  secondaryText?: string;
  secondaryHref?: string;
}

const {
  title = 'Ready to Get Started?',
  description = 'Get in touch to discuss your project. We provide free, no-obligation quotes for all planned work across our service area.',
  primaryText = 'Request a Quote',
  primaryHref = '/contact/',
  secondaryText = 'View Our Services',
  secondaryHref = '/services/',
} = Astro.props;
---

<section class="cta-band">
  <div class="cta-band__inner container">
    <div class="cta-band__content">
      <h2 class="cta-band__title">{title}</h2>
      <p class="cta-band__desc">{description}</p>
    </div>
    <div class="cta-band__actions">
      <a href={primaryHref} class="btn btn--primary btn--large">{primaryText}</a>
      {secondaryText && <a href={secondaryHref} class="btn btn--secondary btn--large">{secondaryText}</a>}
    </div>
  </div>
</section>

<style>
  .cta-band {
    background: linear-gradient(135deg, rgba(198, 168, 106, 0.08) 0%, rgba(43, 46, 52, 1) 50%, rgba(198, 168, 106, 0.05) 100%);
    border-top: 1px solid rgba(198, 168, 106, 0.15);
    border-bottom: 1px solid rgba(198, 168, 106, 0.15);
    padding: 5rem 0;
  }

  .cta-band__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
  }

  .cta-band__title {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    margin-bottom: 0.75rem;
  }

  .cta-band__desc {
    color: var(--color-silver);
    opacity: 0.8;
    max-width: 500px;
    margin: 0;
  }

  .cta-band__actions {
    display: flex;
    gap: 1rem;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .cta-band__inner {
      flex-direction: column;
      text-align: center;
    }
    .cta-band__desc {
      max-width: none;
    }
    .cta-band__actions {
      flex-direction: column;
      width: 100%;
    }
    .cta-band__actions .btn {
      text-align: center;
    }
  }
</style>
