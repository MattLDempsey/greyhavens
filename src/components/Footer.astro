---
import { services } from '../data/services';
import { locations } from '../data/locations';

const keyServices = services.slice(0, 6);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer__main">
    <div class="container">
      <div class="footer__grid">
        <!-- Brand -->
        <div class="footer__brand">
          <div class="footer__logo">
            <span class="footer__logo-mark">GH</span>
            <div>
              <span class="footer__logo-name">Grey Havens</span>
              <span class="footer__logo-tag">Electrical & Smart Home</span>
            </div>
          </div>
          <p class="footer__desc">
            Premium electrical and smart home services across Essex and Suffolk.
            Quality workmanship, modern solutions, and trusted local service.
          </p>
          <div class="footer__contact-info">
            <a href="tel:01206000000" class="footer__contact-link">01206 000 000</a>
            <a href="mailto:hello@thegreyhavens.co.uk" class="footer__contact-link">hello@thegreyhavens.co.uk</a>
          </div>
        </div>

        <!-- Services -->
        <div class="footer__col">
          <h4 class="footer__heading">Services</h4>
          <ul class="footer__links">
            {keyServices.map(service => (
              <li><a href={`/services/${service.slug}/`}>{service.name}</a></li>
            ))}
            <li><a href="/services/">View All Services</a></li>
          </ul>
        </div>

        <!-- Areas -->
        <div class="footer__col">
          <h4 class="footer__heading">Areas We Cover</h4>
          <ul class="footer__links">
            {locations.map(location => (
              <li><a href={`/locations/${location.slug}/`}>{location.name}</a></li>
            ))}
          </ul>
        </div>

        <!-- Quick Links -->
        <div class="footer__col">
          <h4 class="footer__heading">Company</h4>
          <ul class="footer__links">
            <li><a href="/about/">About Us</a></li>
            <li><a href="/contact/">Contact</a></li>
            <li><a href="/services/">Our Services</a></li>
            <li><a href="/locations/">Service Areas</a></li>
          </ul>
          <div class="footer__cta-block">
            <a href="/contact/" class="btn btn--primary">Request a Quote</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container">
      <p>&copy; {year} Grey Havens. All rights reserved.</p>
      <p class="footer__legal">
        <a href="#">Privacy Policy</a>
        <span class="footer__sep">|</span>
        <a href="#">Terms & Conditions</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-black);
    border-top: 1px solid rgba(75, 80, 87, 0.3);
  }

  .footer__main {
    padding: 4rem 0 3rem;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 3rem;
  }

  .footer__logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .footer__logo-mark {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-gold);
    width: 42px;
    height: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--color-gold);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .footer__logo-name {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-white);
    display: block;
    letter-spacing: 0.04em;
  }

  .footer__logo-tag {
    font-family: var(--font-body);
    font-size: 0.65rem;
    color: var(--color-silver);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.6;
  }

  .footer__desc {
    font-size: 0.9rem;
    color: var(--color-silver);
    opacity: 0.8;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .footer__contact-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer__contact-link {
    font-size: 0.9rem;
    color: var(--color-gold);
    text-decoration: none;
    transition: opacity 0.3s;
  }

  .footer__contact-link:hover {
    opacity: 0.8;
    color: var(--color-gold);
  }

  .footer__heading {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-white);
    letter-spacing: 0.06em;
    margin-bottom: 1.25rem;
    text-transform: uppercase;
  }

  .footer__links {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer__links a {
    font-size: 0.875rem;
    color: var(--color-silver);
    opacity: 0.7;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .footer__links a:hover {
    color: var(--color-gold);
    opacity: 1;
  }

  .footer__cta-block {
    margin-top: 2rem;
  }

  .footer__bottom {
    border-top: 1px solid rgba(75, 80, 87, 0.2);
    padding: 1.5rem 0;
  }

  .footer__bottom .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer__bottom p {
    font-size: 0.8rem;
    color: var(--color-silver);
    opacity: 0.5;
    margin: 0;
  }

  .footer__legal a {
    color: var(--color-silver);
    opacity: 0.5;
    text-decoration: none;
    transition: opacity 0.3s;
  }

  .footer__legal a:hover {
    opacity: 0.8;
    color: var(--color-silver);
  }

  .footer__sep {
    margin: 0 0.5rem;
    opacity: 0.3;
  }

  @media (max-width: 900px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
    }
    .footer__brand {
      grid-column: span 2;
    }
  }

  @media (max-width: 580px) {
    .footer__grid {
      grid-template-columns: 1fr;
    }
    .footer__brand {
      grid-column: span 1;
    }
    .footer__bottom .container {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }
</style>
