---
interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  primaryCta?: { text: string; href: string };
  secondaryCta?: { text: string; href: string };
  compact?: boolean;
}

const { title, subtitle, description, primaryCta, secondaryCta, compact = false } = Astro.props;
---

<section class:list={['hero', { 'hero--compact': compact }]}>
  <div class="hero__overlay"></div>
  <div class="hero__content container">
    {subtitle && <span class="hero__subtitle">{subtitle}</span>}
    <h1 class="hero__title">{title}</h1>
    {description && <p class="hero__desc">{description}</p>}
    {(primaryCta || secondaryCta) && (
      <div class="hero__actions">
        {primaryCta && <a href={primaryCta.href} class="btn btn--primary btn--large">{primaryCta.text}</a>}
        {secondaryCta && <a href={secondaryCta.href} class="btn btn--secondary btn--large">{secondaryCta.text}</a>}
      </div>
    )}
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: 85vh;
    padding: 8rem 0 6rem;
    background: linear-gradient(135deg, var(--color-charcoal) 0%, var(--color-black) 60%, #1f2127 100%);
    overflow: hidden;
  }

  .hero--compact {
    min-height: auto;
    padding: 10rem 0 5rem;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 70% 20%, rgba(198, 168, 106, 0.06) 0%, transparent 60%),
      radial-gradient(ellipse at 20% 80%, rgba(75, 80, 87, 0.15) 0%, transparent 50%);
    pointer-events: none;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    max-width: 800px;
  }

  .hero__subtitle {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-gold);
    margin-bottom: 1.25rem;
  }

  .hero__title {
    font-size: clamp(2.25rem, 5.5vw, 3.75rem);
    font-weight: 500;
    line-height: 1.15;
    color: var(--color-white);
    margin-bottom: 1.5rem;
  }

  .hero__desc {
    font-size: 1.15rem;
    line-height: 1.8;
    color: var(--color-silver);
    max-width: 600px;
    margin-bottom: 2.5rem;
    opacity: 0.85;
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero--compact .hero__title {
    font-size: clamp(1.75rem, 4.5vw, 2.75rem);
    margin-bottom: 1rem;
  }

  .hero--compact .hero__desc {
    font-size: 1.05rem;
    margin-bottom: 2rem;
  }

  @media (max-width: 640px) {
    .hero {
      padding: 7rem 0 4rem;
      min-height: 70vh;
    }
    .hero--compact {
      padding: 8rem 0 3.5rem;
    }
    .hero__actions {
      flex-direction: column;
    }
    .hero__actions .btn {
      text-align: center;
    }
  }
</style>
